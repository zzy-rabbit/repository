	var table Comment
	table.FromModel(comment)
	err := s.db.Create(&table).Error
	if xerror.Error(err) {
		s.logger.Error(ctx, "add comment %+v fail %v", comment, err)
		return 0, transError(err)
	}
	return table.ID, nil
}

func (s *session) UpdateComment(ctx context.Context, comment model.Comment) xerror.IError {
	var table Comment
	table.FromModel(comment)
	err := s.db.Where("identify = ?", table.ID).Updates(&table).Error
	if xerror.Error(err) {
		s.logger.Error(ctx, "update comment %+v fail %v", comment, err)
		return transError(err)
	}
	return nil
}

func (s *session) DeleteComments(ctx context.Context, identifies ...model.Identify) xerror.IError {
	ids := make([]string, 0, len(identifies))
	for _, identify := range identifies {
		ids = append(ids, identify.ID)
	}

	// 删除comment
	err := s.db.Where("identify in ?", ids).Delete(&Comment{}).Error
	if xerror.Error(err) {
		s.logger.Error(ctx, "delete comments %+v fail %v", ids, err)
		return transError(err)
	}
	return nil
}

func (s *session) GetComments(ctx context.Context, condition model.CommentCondition) ([]model.Comment, model.PageInfo, xerror.IError) {
	db := s.db
	if len(condition.IDs) > 0 {
		db = db.Where("identify in ?", condition.IDs)
	}
	total := int64(0)
	if condition.PageQuery != nil && condition.PageQuery.Num > 0 && condition.PageQuery.Size > 0 {
		err := db.Model(&Comment{}).Count(&total).Error
		if xerror.Error(err) {
			s.logger.Error(ctx, "query comments count by condition %+v fail %v", condition, err)
			return nil, model.PageInfo{}, transError(err)
		}
		offset := (condition.PageQuery.Num - 1) * condition.PageQuery.Size
		db = db.Offset(offset).Limit(condition.PageQuery.Size)
	}

	var tables []Comment
	err := db.Find(&tables).Error
	if xerror.Error(err) {
		s.logger.Error(ctx, "query comments by condition %+v fail %v", condition, err)
		return nil, model.PageInfo{}, transError(err)
	}
	comments := make([]model.Comment, 0, len(tables))
	for _, table := range tables {
		comments = append(comments, table.ToModel())
	}
	return comments, model.PageInfo{
		Count: len(tables),
		Total: int(total),
	}, nil
}

func (s *service) Rating(ctx context.Context, rating model.Rating) xerror.IError {
	defer xtrace.Trace(ctx)(rating)

	ok, xerr := s.IDatabase.GetDB(ctx).CheckRepositoryPassword(ctx, model.Repository{
		Identify: rating.Identify,
		Password: rating.Password,
	})
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx, "check repository %s password fail %v", rating.Identify, xerr)
		return xerr
	}
	if !ok {
		s.ILogger.Error(ctx, "repository %+v password error", rating.Identify)
		return xerror.Extend(xerror.ErrPermissionDenied, "repository %s access denied", rating.ID)
	}
	return s.IDatabase.GetDB(ctx).Rating(ctx, rating)
}

func (s *service) AddComment(ctx context.Context, comment model.Comment) (model.Identify, xerror.IError) {
	defer xtrace.Trace(ctx)(comment)
	if comment.ID == "" {
		comment.ID = uuid.New().String()
	}

	repositories, _, xerr := s.GetRepositories(ctx, model.RepositoryCondition{IDs: []string{comment.Repository}})
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx, "get repository %s fail %v", comment.Repository, xerr)
		return model.Identify{}, xerr
	}
	if len(repositories) == 0 {
		s.ILogger.Error(ctx, "repository %s not found", comment.Repository)
		return model.Identify{}, xerror.Extend(xerror.ErrNotFound, "repository %s not found", comment.Repository)
	}

	_, xerr = s.IDatabase.GetDB(ctx).AddComment(ctx, comment)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx, "add comment %+v fail %v", comment, xerr)
		return model.Identify{}, xerr
	}
	return comment.Identify, nil
}


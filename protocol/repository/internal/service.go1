package internal

import (
	"github.com/gofiber/fiber/v2"
	bpmodel "github.com/zzy-rabbit/bp/model"
	"github.com/zzy-rabbit/repository/model"
	"github.com/zzy-rabbit/xtools/xerror"
	"time"
)

func (s *service) AddRepository(ctx *fiber.Ctx) error {
	var header bpmodel.Header
	var repository model.Repository
	xerr := s.IHttp.ParseBodyParams(ctx, &header, &repository)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "parse body params fail %v", xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}

	repository.CreateAt = time.Now().Unix()
	if repository.ExpireAt < repository.CreateAt {
		xerr = xerror.Extend(xerror.ErrInvalidParam, "expire time %d must be greater than create time %d", repository.ExpireAt, repository.CreateAt)
		s.ILogger.Error(ctx.UserContext(), "%+v %v", repository, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}

	identify, xerr := s.IRepository.AddRepository(ctx.UserContext(), repository)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "add repository %+v fail %v", repository, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}
	return ctx.JSON(&bpmodel.HttpResponse{
		IError: xerror.ErrSuccess,
		Data:   identify,
	})
}


package internal

import (
	"github.com/gofiber/fiber/v2"
	bpmodel "github.com/zzy-rabbit/bp/model"
	"github.com/zzy-rabbit/ishare/model"
	"github.com/zzy-rabbit/xtools/xerror"
	"time"
)

func (s *service) AddShare(ctx *fiber.Ctx) error {
	var header bpmodel.Header
	var share model.Share
	xerr := s.IHttp.ParseBodyParams(ctx, &header, &share)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "parse body params fail %v", xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}

	share.CreateAt = time.Now().Unix()
	if share.ExpireAt < share.CreateAt {
		xerr = xerror.Extend(xerror.ErrInvalidParam, "expire time %d must be greater than create time %d", share.ExpireAt, share.CreateAt)
		s.ILogger.Error(ctx.UserContext(), "%+v %v", share, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}

	identify, xerr := s.IShare.AddShare(ctx.UserContext(), share)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "add share %+v fail %v", share, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}
	return ctx.JSON(&bpmodel.HttpResponse{
		IError: xerror.ErrSuccess,
		Data:   identify,
	})
}


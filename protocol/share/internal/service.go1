	xerr := s.IHttp.ParseBodyParams(ctx, &header, &shares)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "parse body params fail %v", xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}

	xerr = s.IShare.DeleteShares(ctx.UserContext(), shares...)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "delete shares %+v fail %v", shares, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}
	return ctx.JSON(&bpmodel.HttpResponse{
		IError: xerror.ErrSuccess,

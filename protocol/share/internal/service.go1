func (s *service) GetShares(ctx *fiber.Ctx) error {
	var header bpmodel.Header
	var condition model.ShareCondition
	xerr := s.IHttp.ParseQueryParams(ctx, &header, &condition)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "parse query params fail %v", xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}

	// 查找未过期的内容
	condition.ExpireAfter = time.Now().Unix()
	condition.ExpireBefore = 0
	shares, page, xerr := s.IShare.GetShares(ctx.UserContext(), condition)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "get shares %+v fail %v", condition, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}
	return ctx.JSON(&bpmodel.HttpResponse{
		IError: xerror.ErrSuccess,
		Data: model.PaginatedData[model.Share]{
			PageInfo: page,
			List:     shares,
		},
	})
}

func (s *service) GetShareFiles(ctx *fiber.Ctx) error {
	var header bpmodel.Header
	var condition model.ShareFilesCondition
	xerr := s.IHttp.ParseBodyParams(ctx, &header, &condition)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "parse query params fail %v", xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}

	// 查找未过期的内容
	content, xerr := s.IShare.GetShareFiles(ctx.UserContext(), condition)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "get shares %+v fail %v", condition.ID, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}
	return ctx.Send(content)
}

func (s *service) CheckSharePassword(ctx *fiber.Ctx) error {
	var header bpmodel.Header
	var share model.Share
	xerr := s.IHttp.ParseBodyParams(ctx, &header, &share)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "parse body params fail %v", xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}

	ok, xerr := s.IShare.CheckSharePassword(ctx.UserContext(), share)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "update share %+v fail %v", share, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}
	if ok {
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerror.ErrSuccess,
		})
	}
	return ctx.JSON(&bpmodel.HttpResponse{
		IError: xerror.ErrPermissionDenied,
	})
}

func (s *service) AddComment(ctx *fiber.Ctx) error {
	var header bpmodel.Header
	var comment model.Comment
	xerr := s.IHttp.ParseBodyParams(ctx, &header, &comment)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "parse body params fail %v", xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}

	comment.IP = ctx.IP()
	comment.UserAgent = ctx.Get("User-Agent")
	comment.Time = time.Now().Unix()
	locations, xerr := s.IRegion.Search(ctx.UserContext(), comment.IP)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "search ip %+v fail %v", comment.IP, xerr)
	} else {
		s.ILogger.Info(ctx.UserContext(), "search ip %s to %s", comment.IP, locations)
	}
	comment.Locations = locations

	identify, xerr := s.IShare.AddComment(ctx.UserContext(), comment)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "add comment %+v fail %v", comment, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}
	return ctx.JSON(&bpmodel.HttpResponse{
		IError: xerror.ErrSuccess,
		Data:   identify,
	})
}

